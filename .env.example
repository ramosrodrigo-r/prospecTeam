# Google Places API key — required for all searches
# Get yours at: https://console.cloud.google.com/apis/credentials
# IMPORTANT: Before running, configure in Google Cloud Console:
#   1. Enable "Places API (New)" in APIs & Services
#   2. Set a $10 billing alert in Billing > Budgets & Alerts
#   3. Set a daily quota cap in APIs & Services > Places API (New) > Quotas
GOOGLE_PLACES_API_KEY=

# Evolution API — required for WhatsApp sending
# Your Evolution API server URL (e.g., http://localhost:8080)
EVOLUTION_API_URL=
# API key from Evolution API dashboard
EVOLUTION_API_KEY=
# Instance name configured in Evolution API
EVOLUTION_INSTANCE=
