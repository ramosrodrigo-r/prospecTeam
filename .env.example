# Google Places API key — required for all searches
# Get yours at: https://console.cloud.google.com/apis/credentials
# IMPORTANT: Before running, configure in Google Cloud Console:
#   1. Enable "Places API (New)" in APIs & Services
#   2. Set a $10 billing alert in Billing > Budgets & Alerts
#   3. Set a daily quota cap in APIs & Services > Places API (New) > Quotas
GOOGLE_PLACES_API_KEY=

# Evolution Go — required for WhatsApp sending
# Your Evolution Go server URL (e.g., http://localhost:8080)
EVOLUTION_API_URL=
# Instance token from Evolution Go (created via POST /instance/create)
# This token identifies AND authenticates your instance — no separate instance name needed
EVOLUTION_API_KEY=

# Zoho SMTP — required for email sending
# Your Zoho Mail email address (e.g., user@yourdomain.com)
ZOHO_SMTP_USER=
# App Password from Zoho Mail > Settings > Security > App Passwords
# If 2FA is disabled, use your regular Zoho password
# NOTE: smtp.zoho.com is for personal accounts. For organizational Zoho, use smtppro.zoho.com (change in src/services/zoho.js)
ZOHO_SMTP_PASS=
# Email subject line — supports {{nome}}, {{rating}}, {{categoria}}, {{cidade}} variables
EMAIL_SUBJECT=Site profissional para {{nome}}
